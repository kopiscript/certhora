generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserType {
  ORGANIZER
  ADMIN
}

enum Tier {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum EmailStatus {
  PENDING
  QUEUED
  SENT
  FAILED
  BOUNCED
}

enum EventStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

// ─── Auth + User ──────────────────────────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  emailVerified     DateTime?
  image             String?
  name              String?
  passwordHash      String?
  userType          UserType  @default(ORGANIZER)
  isVerified        Boolean   @default(false)
  verificationToken String?   @unique
  resetToken        String?   @unique
  resetExpires      DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  organizer           Organizer?
  paymentTransactions PaymentTransaction[]

  @@index([verificationToken])
  @@index([resetToken])
}

// ─── NextAuth Adapter Models ──────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  expires    DateTime
  token      String   @unique

  @@unique([identifier, token])
}

// ─── Business Models ──────────────────────────────────────────────────────────

model Organizer {
  organizerCd   String    @id @db.VarChar(4)
  userId        String    @unique
  orgName       String
  socialLink    String?
  tier          Tier      @default(FREE)
  certQuota     Int       @default(0)
  expiryDate    DateTime?
  subscribeDate DateTime?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  events       Event[]
  subscription Subscription?
  templates    Template[]

  @@index([tier])
}

model Subscription {
  organizerCd String    @id @db.VarChar(4)
  tier        Tier
  certQuota   Int
  createdAt   DateTime  @default(now())
  suspendDate DateTime?

  organizer Organizer @relation(fields: [organizerCd], references: [organizerCd], onDelete: Cascade)

  @@index([tier])
  @@index([suspendDate])
}

// ─── Template (organizer-owned, reusable across events) ───────────────────────

model Template {
  id           String  @id @default(cuid())
  organizerCd  String  @db.VarChar(4)
  name         String  // display name e.g. "Workshop Blue"
  imageUrl     String? // background image URL (local /uploads or future R2)

  primaryColor String  @default("#1D4ED8") @db.VarChar(16)

  // ── Name overlay ──
  nameCenterX  Float   @default(600)
  nameY        Float   @default(340)
  nameMaxWidth Float   @default(840)
  nameFontSize Float   @default(52)
  nameFont     String  @default("Arial, Helvetica, sans-serif") @db.VarChar(64)
  nameColor    String  @default("#1E293B") @db.VarChar(18)

  // ── QR code ──
  qrX          Float   @default(1010)
  qrY          Float   @default(628)
  qrSize       Float   @default(140)

  // ── Design ──
  certIdFont    String  @default("monospace") @db.VarChar(64)
  certIdColor   String  @default("#64748B") @db.VarChar(18)
  showWatermark Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizer Organizer @relation(fields: [organizerCd], references: [organizerCd], onDelete: Cascade)
  events    Event[]

  @@index([organizerCd])
}

model Event {
  eventCode   String      @id @db.VarChar(10)
  templateId  String?
  status      EventStatus @default(DRAFT)
  eventName   String
  eventDate   DateTime?
  issuedDate  DateTime?
  expiryDate  DateTime?
  description String?     @db.VarChar(1500)
  skills      String[]
  organizerCd String      @db.VarChar(4)
  createdAt   DateTime    @default(now())

  organizer    Organizer       @relation(fields: [organizerCd], references: [organizerCd], onDelete: Restrict)
  template     Template?       @relation(fields: [templateId], references: [id], onDelete: SetNull)
  certificates Certificate[]
  feedback     EventFeedback[]

  @@index([organizerCd])
  @@index([status])
  @@index([eventDate])
  @@index([expiryDate])
}

model Certificate {
  certId           String      @id @db.VarChar(12)
  participantName  String
  participantEmail String      @db.VarChar(100)
  eventCode        String      @db.VarChar(10)
  createdAt        DateTime    @default(now())
  shareCount       Int         @default(0)
  viewCount        Int         @default(0)
  emailStatus      EmailStatus @default(PENDING)
  metadata         Json?
  queuedAt         DateTime?
  sendAttempts     Int         @default(0)

  event Event @relation(fields: [eventCode], references: [eventCode], onDelete: Restrict)

  @@index([eventCode])
  @@index([participantEmail])
  @@index([emailStatus])
  @@index([eventCode, emailStatus])
}

model EventFeedback {
  id        Int      @id @default(autoincrement())
  eventCode String   @db.VarChar(10)
  npsScore  Int
  comment   String?
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventCode], references: [eventCode], onDelete: Cascade)

  @@index([eventCode])
}

model PaymentTransaction {
  id            Int           @id @default(autoincrement())
  userId        String
  billcode      String        @db.VarChar(100)
  amount        Decimal       @db.Decimal(10, 2)
  externalRef   String?       @db.VarChar(60)
  tierRequested Tier
  certQuotaReq  Int
  status        PaymentStatus @default(PENDING)
  refno         String?       @db.VarChar(50)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([status])
  @@index([billcode])
  @@index([status, createdAt])
}
